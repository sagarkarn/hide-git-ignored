{
  "name": "hide-git-ignored-explorer-toggle",
  "displayName": "Hide Git Ignored Explorer Toggle",
  "version": "0.0.2",
  "description": "Toggle visibility of git-ignored files and folders in Explorer.",
  "icon": "media/extension-icon.png",
  "publisher": "sagarkarn",
  "repository": {
    "type": "git",
    "url": "https://github.com/sagarkarn/hide-git-ignored.git"
  },
  "homepage": "https://github.com/sagarkarn/hide-git-ignored#readme",
  "bugs": {
    "url": "https://github.com/sagarkarn/hide-git-ignored/issues"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "contributes": {
    "commands": [
      {
        "command": "hideGitIgnored.toggle",
        "title": "Hide Git-Ignored: Toggle",
        "icon": "$(eye-closed)"
      },
      {
        "command": "hideGitIgnored.hide",
        "title": "Hide Git-Ignored: Hide"
      },
      {
        "command": "hideGitIgnored.show",
        "title": "Hide Git-Ignored: Show"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "hideGitIgnored.toggle",
          "when": "view == workbench.explorer.fileView",
          "group": "navigation@99"
        }
      ]
    }
  },
  "keywords": [
    "git",
    "explorer",
    "ignore",
    "toggle"
  ],
  "author": "Sagar Karn",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.9.3"
  }
}
